APP_ENV=local
APP_NAME=CodeScribe
LOG_LEVEL=INFO
API_PREFIX=/api/v1
CODESCRIBE_MODE=webhook_server

# Local development defaults. Docker Compose overrides DATABASE_URL and REDIS_URL for containers.
DATABASE_URL=sqlite+aiosqlite:///./codescribe.db
REDIS_URL=redis://localhost:6379/0

GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_TOKEN=

LLM_PROVIDER=ollama
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
LOCAL_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LOCAL_MODEL_TIMEOUT_SECONDS=45
GENERIC_LLM_API_BASE_URL=
GENERIC_LLM_API_KEY=
GENERIC_LLM_MODEL=gpt-4o-mini

AUTO_POST_REVIEWS=false
POST_PR_COMMENT=false
TRAINING_DATASET_PATH=outputs/training_dataset.jsonl

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

PUBLISH_MODE=dry_run
